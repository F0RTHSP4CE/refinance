# any string to be used as a secret key to sign x-token
REFINANCE_SECRET_KEY=0000-1111-2222-3333-4444-5555

# secret used to authorize POS endpoints (x-pos-secret header)
REFINANCE_POS_SECRET=change-me-pos-secret

# Telegram bot token used for DM delivery and website login verification
REFINANCE_TELEGRAM_BOT_API_TOKEN=0000000:abcdef0123456789
# Telegram bot username used by the ui-new website login widget and deep link
REFINANCE_TELEGRAM_BOT_USERNAME=refinance_bot

# web ui url (used for constructing auth links)
# dev suggestion for ui-new: http://localhost:5173
REFINANCE_UI_URL=http://localhost:5173

# web ui secret key for Flask session signing
REFINANCE_UI_SECRET_KEY=change-me

# public api url (needed for deposit provider callbacks)
# dev : http://localhost:8000
REFINANCE_API_URL=http://localhost:8000

# cryptapi deposit provider credentials (optional in dev)
REFINANCE_CRYPTAPI_ADDRESS_ERC20_USDT=0xxxxxxxxxxxxx
REFINANCE_CRYPTAPI_ADDRESS_TRC20_USDT=Txxxxxxxxxxxxx

# database connection (fresh dev/ci compose uses local trust auth by default;
# keep a password here if your existing local Postgres volume still requires one)
REFINANCE_DATABASE_URL=postgresql://postgres@db:5432/refinance


# fee presets (tag-based amounts) as JSON list
# example: resident tag id=2, member tag id=14
REFINANCE_FEE_PRESETS=[{"tag_id":2,"currency":"usd","amount":"42"},{"tag_id":2,"currency":"gel","amount":"115"},{"tag_id":14,"currency":"usd","amount":"25"},{"tag_id":14,"currency":"gel","amount":"70"}]
