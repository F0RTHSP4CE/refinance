{% extends 'base.jinja2' %}
{% from 'widgets/entity_selector.jinja2' import entity_selector %}

{% block title %}Currency exchange{% endblock %}

{% block content %}
<div class="xform-wrap">

  <form method="post" id="xform" novalidate>
    {{ form.hidden_tag() }}
    <input type="hidden" name="xmode" id="xmode" value="sell">

    <div class="xform-currencies">
      <div class="xform-currency-slot">
        <span class="xform-panel-role">SELL</span>
        {{ form.source_currency(class="xform-currency", id="source_currency") }}
      </div>
      <div class="xform-currency-arrow" aria-hidden="true">→</div>
      <div class="xform-currency-slot">
        <span class="xform-panel-role">GET</span>
        {{ form.target_currency(class="xform-currency", id="target_currency") }}
      </div>
    </div>

    <div class="xform-panels">
      <div class="xform-panel" id="xpanel-from">
        {{ form.source_amount(class="xform-amount", id="source_amount", placeholder="0.00", autocomplete="off", inputmode="decimal") }}
      </div>

      <div class="xform-panel" id="xpanel-to">
        {{ form.target_amount(class="xform-amount", id="target_amount", placeholder="0.00", autocomplete="off", inputmode="decimal") }}
      </div>
    </div>

    <div class="xform-entity deposit-topup-form">
      <div class="xform-entity-label">ENTITY</div>
      {{ entity_selector('entity', g.actor_entity.name, g.actor_entity.id, show_id_input=False) }}
    </div>

    {% if form.errors %}
    <ul class="xform-errors">
      {% for field_name, field_errors in form.errors|dictsort if field_errors %}
      {% for error in field_errors %}
      <li>{{ form[field_name].label.text }}: {{ error }}</li>
      {% endfor %}
      {% endfor %}
    </ul>
    {% endif %}

    <button type="submit" class="xform-submit">PREVIEW EXCHANGE →</button>
  </form>

  <hr class="xform-divider">
  <p>
    <a href="{{ url_for('exchange.auto_balance_preview') }}" class="xform-aux-link">⚖️ AUTO-BALANCE DEBTS</a>
    — automatically exchange available currencies to cover any negative balances
    for residents, members and ex-residents.
  </p>
</div>

<script src="/static/js/entitySelector.js"></script>
<script>
(function () {
  var xmode = document.getElementById('xmode');
  var fromAmt = document.getElementById('source_amount');
  var toAmt = document.getElementById('target_amount');

  fromAmt.addEventListener('input', function () {
    xmode.value = 'sell';
    toAmt.value = '';
  });

  toAmt.addEventListener('input', function () {
    xmode.value = 'get';
    fromAmt.value = '';
  });
})();
</script>
{% endblock %}