{% extends 'base.jinja2' %}

{% block title %}Auto-balance preview{% endblock %}

{% block content %}
<div class="xform-wrap">

  <p>The following exchanges will be made to cover negative balances for residents, members and ex-residents. <strong>Draft balances are not counted.</strong></p>

  {% if preview.plans %}
  <table>
    <thead>
      <tr>
        <th>Entity</th>
        <th>Sell</th>
        <th></th>
        <th>Get</th>
        <th>Rate</th>
      </tr>
    </thead>
    <tbody>
      {% for plan in preview.plans %}
      {% for exc in plan.exchanges %}
      <tr>
        {% if loop.first %}
        <td rowspan="{{ plan.exchanges | length }}">
          <a href="/entities/{{ plan.entity_id }}">{{ plan.entity_name }}</a>
        </td>
        {% endif %}
        <td>{{ exc.source_amount }} {{ exc.source_currency | upper }}</td>
        <td>→</td>
        <td>{{ exc.target_amount }} {{ exc.target_currency | upper }}</td>
        <td>{{ exc.rate }}</td>
      </tr>
      {% endfor %}
      {% endfor %}
    </tbody>
  </table>

  <form method="post" action="{{ url_for('exchange.auto_balance_run') }}" onsubmit="this.querySelector('button').disabled=true">
    <div class="xform-actions" style="margin-top:1.5rem">
      <button type="submit" class="xform-submit">⚡ EXECUTE AUTO-BALANCE</button>
      <a href="{{ url_for('exchange.index') }}" class="xform-cancel">← CANCEL</a>
    </div>
    <p style="margin-top:0.75rem; font-weight:700;">⚠️ This will create real transactions!</p>
  </form>

  {% else %}
  <p>✅ No exchanges needed — all eligible entities have non-negative balances in every currency.</p>
  <a href="{{ url_for('exchange.index') }}" class="xform-aux-link">← Back to exchange</a>
  {% endif %}

</div>
{% endblock %}
