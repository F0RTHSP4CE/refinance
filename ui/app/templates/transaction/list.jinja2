{% extends "base.jinja2" %}
{% from "transaction/macro_list.jinja2" import transaction_list with context %}
{% from 'widgets/pagination.jinja2' import pagination_control %}

{% block title %}Transactions{% endblock %}

{% block content %}
<div class="tx-page-actions">
    <a href="{{ url_for('transaction.add') }}" class="tx-add-btn">+ NEW</a>
</div>

{{ transaction_list(transactions) }}
{{ pagination_control(page, total, limit) }}

<script>
document.querySelectorAll('.transaction-table tr[data-href]').forEach(function(row) {
    row.addEventListener('click', function(e) {
        if (!e.target.closest('a')) {
            window.location.href = row.dataset.href;
        }
    });
});
</script>

<script src="/static/js/entitySelector.js"></script>
{% endblock %}