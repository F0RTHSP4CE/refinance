{% extends "base.jinja2" %}
{% from 'widgets/pagination.jinja2' import pagination_control %}
{% from 'widgets/treasury_inline.jinja2' import treasury_inline %}

{% block title %}Treasuries{% endblock %}
{% block content %}
<p><a href="{{ url_for('treasury.add') }}">Add Treasury</a></p>
{% if treasuries %}
<table class="treasury-table">
    <thead>
        <tr>
            <th>Name</th>
            <th class="treasury-col-balance">Balance</th>
            <th>Comment</th>
        </tr>
    </thead>
    <tbody>
        {% for t in treasuries %}
        <tr{% if not t.active %} class="secondary" {% endif %}>
            <td class="treasury-col-name">{{ treasury_inline(t) }}</td>
            <td class="treasury-col-balance">
                {% for currency, amount in t.balances.completed.items() if amount | float != 0 %}
                <div class="treasury-balance-row">
                    <span class="treasury-balance-amount">{{ amount }}</span>
                    <span class="treasury-balance-currency">{{ currency|upper }}</span>
                </div>
                {% endfor %}
                {% for currency, amount in t.balances.draft.items() if amount | float != 0 %}
                <div class="treasury-balance-row treasury-balance-draft">
                    <span class="treasury-balance-amount">{{ amount }}</span>
                    <span class="treasury-balance-currency">{{ currency|upper }}</span>
                </div>
                {% endfor %}
            </td>
            <td class="treasury-col-comment">{{ t.comment or '' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
<p>No treasuries.</p>
{% endif %}
{{ pagination_control(page, total, limit, 'treasury.list') }}
{% endblock %}