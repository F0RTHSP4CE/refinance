{% extends 'base.jinja2' %}
{% from 'widgets/entity_selector.jinja2' import entity_selector %}

{% block title %}Add split {{ split.id }} participant{% endblock %}

{% block content %}
<div class="transaction-form-layout shortcut-form-container">
    <section class="entry-form-card">
        <form method="post" class="entry-form">
            {{ form_entity.hidden_tag() }}

            <div class="form-group">
                <label class="form-label">Entity</label>
                {{ entity_selector('entity', g.actor_entity.name, g.actor_entity.id, show_id_input=False) }}
            </div>

            <div class="form-row">
                <div class="form-field form-field-amount">
                    <label class="form-label" for="fixed_amount">Amount <span style="font-weight:400; opacity:0.5; font-size:0.85em;">(optional)</span></label>
                    {{ form_entity.fixed_amount(class_='form-input', placeholder=split.share_preview.next_share, step='0.01') }}
                    {% if form_entity.fixed_amount.description %}
                    <div class="field-description">{{ form_entity.fixed_amount.description }}</div>
                    {% endif %}
                </div>
                <div class="form-field form-field-currency">
                    <label class="form-label" style="visibility:hidden;">_</label>
                    <div class="split-currency-badge">{{ split.currency | upper }}</div>
                </div>
            </div>

            <div class="form-actions">
                {{ form_entity.submit(class_='big-button', value='Add Participant') }}
            </div>
        </form>
    </section>

    <details class="entry-form-card">
        <summary style="cursor:pointer; font-weight:600; margin: -1rem -1.1rem; padding: 1rem 1.1rem;">Add by tag instead</summary>
        <form method="post" class="entry-form" style="margin-top: 1rem;">
            {{ form_tag.hidden_tag() }}

            <div class="form-group">
                <label class="form-label" for="entity_tag_id">Entity Tag</label>
                {{ form_tag.entity_tag_id(class_='form-input') }}
            </div>

            <div class="form-row">
                <div class="form-field form-field-amount">
                    <label class="form-label" for="fixed_amount">Amount <span style="font-weight:400; opacity:0.5; font-size:0.85em;">(optional)</span></label>
                    {{ form_tag.fixed_amount(class_='form-input', step='0.01') }}
                </div>
                <div class="form-field form-field-currency">
                    <label class="form-label" style="visibility:hidden;">_</label>
                    <div class="split-currency-badge">{{ split.currency | upper }}</div>
                </div>
            </div>

            <div class="form-actions">
                {{ form_tag.submit(class_='big-button') }}
            </div>
        </form>
    </details>
</div>

<script src="/static/js/entitySelector.js"></script>
{% endblock %}