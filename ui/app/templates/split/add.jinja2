{% extends 'base.jinja2' %}
{% from 'widgets/entity_selector.jinja2' import entity_selector %}
{% from 'widgets/tag_selector.jinja2' import tag_selector %}

{% block title %}New split{% endblock %}

{% block content %}
<div class="transaction-form-layout shortcut-form-container">
    <section class="entry-form-card">
        <form method="post" class="entry-form">
            {{ form.hidden_tag() }}

            <div class="form-group">
                <label class="form-label">Recipient</label>
                {{ entity_selector('recipient_entity', g.actor_entity.name, g.actor_entity.id, show_id_input=False) }}
            </div>

            <div class="form-row">
                <div class="form-field form-field-amount">
                    <label class="form-label" for="amount">Amount</label>
                    {{ form.amount(class_='form-input', step='0.01') }}
                </div>
                <div class="form-field form-field-currency">
                    <label class="form-label" for="currency">Currency</label>
                    {{ form.currency(class_='form-input') }}
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="comment">Comment</label>
                {{ form.comment(class_='form-input') }}
            </div>

            <div class="form-actions">
                {{ form.submit(class_='big-button', value='Create Split') }}
            </div>
        </form>
    </section>
</div>

<script src="/static/js/entitySelector.js"></script>
{% endblock %}